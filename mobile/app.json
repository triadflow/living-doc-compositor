{
  "expo": {
    "name": "Living Docs",
    "slug": "living-docs",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "livingdocs",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.triadflow.livingdocs",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.triadflow.livingdocs"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#0969da"
        }
      ],
      "./plugins/withPreviewNotificationsOnly",
      "expo-asset",
      "expo-sqlite"
    ],
    "extra": {
      "githubClientId": "Ov23li7P0RcGNQVDBMM9",
      "eas": {
        "projectId": "94670052-2f49-4ec0-b569-bd0cac302ad9"
      }
    },
    "owner": "triadflow"
  }
}

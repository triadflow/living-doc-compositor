{
  "expo": {
    "name": "Living Docs",
    "slug": "living-docs",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "livingdocs",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.triadflow.livingdocs",
      "supportsTablet": true
    },
    "android": {
      "package": "com.triadflow.livingdocs"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#0969da"
        }
      ]
    ],
    "extra": {
      "githubClientId": "REPLACE_WITH_GITHUB_OAUTH_CLIENT_ID",
      "repoOwner": "triadflow",
      "repoName": "living-doc-compositor",
      "pagesBase": "https://triadflow.github.io/living-doc-compositor/"
    }
  }
}

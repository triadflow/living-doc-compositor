{
  "expo": {
    "name": "Living Docs",
    "slug": "living-docs",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "livingdocs",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.triadflow.livingdocs",
      "supportsTablet": true
    },
    "android": {
      "package": "com.triadflow.livingdocs"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#0969da"
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "githubClientId": "Ov23li7P0RcGNQVDBMM9"
    }
  }
}

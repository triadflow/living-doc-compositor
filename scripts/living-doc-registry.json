{
  "schemaVersion": 1,

  "entityTypes": {
    "figma-page": {
      "label": "Figma Page",
      "refRender": "link",
      "hrefTemplate": "{figmaCanonicalUrl}?node-id={nodeIdParam}&m=dev",
      "displayKey": "id",
      "valueKey": "nodeId"
    },
    "figma-node": {
      "label": "Figma Node",
      "refRender": "link",
      "hrefTemplate": "{figmaCanonicalUrl}?node-id={nodeIdParam}&m=dev",
      "displayKey": "id",
      "valueKey": "nodeId"
    },
    "code-file": {
      "label": "Code File",
      "refRender": "code-link",
      "hrefTemplate": "../{path}",
      "displayKey": "path",
      "valueKey": "path"
    },
    "artifact-file": {
      "label": "Artifact File",
      "refRender": "code-link",
      "hrefTemplate": "../{path}",
      "displayKey": "path",
      "valueKey": "path"
    },
    "ticket": {
      "label": "Ticket",

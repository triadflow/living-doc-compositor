  "statusSets": {
    "page-status": {
      "values": ["ground-truth", "reference", "deprecated"],
      "tones": {
        "ground-truth": "positive",
        "reference": "neutral",
        "deprecated": "negative"
      }
    },
    "code-status": {
      "values": ["implemented", "partial", "drift", "not-started", "reference-only", "legacy-only"],
      "tones": {
        "implemented": "positive",
        "partial": "warning",
        "drift": "negative",
        "not-started": "neutral",
        "reference-only": "neutral",
        "legacy-only": "negative"
      }
    },
    "block-status": {
      "values": ["built", "partial", "not-built", "gap", "blocked"],
      "tones": {
        "built": "positive",
        "partial": "warning",
        "not-built": "neutral",
        "gap": "negative",
        "blocked": "negative"
      }
    },
    "tooling-status": {
      "values": ["trusted", "usable-with-caveats", "prototype", "broken", "missing"],
      "tones": {
        "trusted": "positive",
        "usable-with-caveats": "warning",
        "prototype": "neutral",
        "broken": "negative",
        "missing": "negative"
      }
    },
    "integration-depth": {
      "values": ["screen-local", "hook-service-contract", "real-backend", "planned"],
      "tones": {
        "screen-local": "negative",
        "hook-service-contract": "warning",
        "real-backend": "positive",
        "planned": "neutral"
      }
    },
    "integration-source": {
      "values": ["real", "mock-api", "screen-local", "planned"],
      "tones": {
        "real": "positive",
        "mock-api": "warning",
        "screen-local": "negative",
        "planned": "neutral"
      }
    },
    "interaction-status": {
      "values": ["wired", "visual-only", "state-unwired", "navigation-unwired", "disabled-by-design"],
      "tones": {
        "wired": "positive",
        "visual-only": "warning",
        "state-unwired": "warning",
        "navigation-unwired": "negative",
        "disabled-by-design": "neutral"
      }
    },
    "probe-status": {
      "values": ["planned", "partial", "ready", "blocked"],
      "tones": {
        "planned": "neutral",
        "partial": "warning",
        "ready": "positive",
        "blocked": "negative"
      }
    },
    "probe-priority": {
      "values": ["blocking", "informational"],
      "tones": {
        "blocking": "warning",
        "informational": "neutral"
      },
      "labels": {
        "blocking": "Gate",
        "informational": "Informational"
      }
    },
    "conformance-state": {
      "values": ["not-assessed", "non-conformant", "partial-conformance", "conformant", "spec-ahead", "no-spec"],
      "tones": {
        "not-assessed": "neutral",
        "non-conformant": "negative",
        "partial-conformance": "warning",
        "conformant": "positive",
        "spec-ahead": "warning",
        "no-spec": "neutral"
      }
    },
    "model-integrity": {
      "values": ["not-started", "specified", "implemented", "verified", "canonical", "drift", "legacy"],
      "tones": {
        "not-started": "neutral",
        "specified": "neutral",
        "implemented": "warning",
        "verified": "positive",
        "canonical": "positive",
        "drift": "negative",
        "legacy": "negative"
      }
    },
    "content-lifecycle": {
      "values": ["not-started", "outlined", "drafted", "revised", "final", "blocked", "published"],
      "tones": {
        "not-started": "neutral",
        "outlined": "neutral",
        "drafted": "warning",
        "revised": "positive",
        "final": "positive",
        "blocked": "negative",
        "published": "positive"
      }
    },
    "narrative-thread-state": {
      "values": ["seeded", "developing", "carrying", "resolved", "missing", "overloaded"],
      "tones": {
        "seeded": "neutral",
        "developing": "warning",
        "carrying": "positive",
        "resolved": "positive",
        "missing": "negative",
        "overloaded": "warning"
      }
    },
    "dependency-state": {
      "values": ["anchored", "fragile", "missing", "contradicted"],
      "tones": {
        "anchored": "positive",
        "fragile": "warning",
        "missing": "negative",
        "contradicted": "negative"
      }
    },
    "continuity-risk": {
      "values": ["stable", "watch", "risk", "broken", "resolved"],
      "tones": {
        "stable": "positive",
        "watch": "neutral",
        "risk": "warning",
        "broken": "negative",
        "resolved": "positive"
      }
    }
  },

  "convergenceCategories": {
    "overview": {
      "label": "Overview",
      "description": "Top-level document summaries and document-wide state compression.",
      "order": 1
    },
    "delivery": {
      "label": "Product Delivery",
      "description": "Product surfaces, implementation depth, and design-to-code delivery structure.",
      "order": 2
    },
    "operations": {
      "label": "Operations",
      "description": "Operational lanes, support work, enablers, and tooling used to run the domain.",
      "order": 3
    },
    "verification": {
      "label": "Proof and Verification",
      "description": "Checks, proofs, findings, decisions, and evidence-bearing system truth.",
      "order": 4
    },
    "content": {
      "label": "Content and Narrative",
      "description": "Writing, structure, themes, storylines, scenes, and continuity control.",
      "order": 5
    }
  },

  "convergenceTypes": {
    "design-code-spec-flow": {
      "name": "Design–Code–Spec Flow",
      "category": "delivery",
      "description": "A product surface where design artifacts, code, specs, and tracked interactions converge into one implementation flow.",
      "structuralContract": "Two-column card grid combining design, code, spec, and interaction references. Use when the section is about one named surface viewed through those converging artifacts.",
      "notFor": [
        "status-only implementation inventories",
        "formal verification or protocol sections",
        "single-lane operational narratives"
      ],
      "icon": "<circle cx='6' cy='6' r='2.5' opacity='.35'/><circle cx='18' cy='6' r='2.5' opacity='.55'/><circle cx='12' cy='18' r='2.5'/><path d='M7.35 7.1l2.95 5.9-1.35.68-2.95-5.9zm9.3 0l1.35.68-2.95 5.9-1.35-.68zM9 5.25h6v1.5H9z'/>",
      "iconColor": "#0f766e",
      "projection": "card-grid",
      "columns": 2,
      "sources": [
        { "key": "pageIds", "entityType": "figma-page", "label": "Pages" },
        { "key": "defaultNodeIds", "entityType": "figma-node", "label": "Defaults" },
        { "key": "codeRefs", "entityType": "code-file", "label": "Code refs" },
        { "key": "specRefIds", "entityType": "ux-spec", "label": "UX spec refs", "resolve": true },
        { "key": "interactionSurfaceIds", "entityType": "interaction-surface", "label": "Tracked interactions", "resolve": true },
        { "key": "ticketIds", "entityType": "ticket", "label": "Tickets" },
        { "key": "notes", "entityType": null, "label": null }
      ],
      "statusFields": [
        { "key": "status", "statusSet": "page-status" },
        { "key": "codeStatus", "statusSet": "code-status" }
      ]
    },

    "status-snapshot": {
      "name": "Status Snapshot",
      "category": "overview",
      "description": "A summary section that compresses the current document into top-level counts and distribution signals.",
      "structuralContract": "Stats-first section with snapshot cards and no item grid requirement. Use for high-level totals and state distribution, not for individual entities.",
      "notFor": [
        "component or capability inventories",
        "decision or finding sections",
        "verification surfaces"
      ],
      "icon": "<rect x='4' y='14' width='3' height='6' rx='1' opacity='.4'/><rect x='10.5' y='9' width='3' height='11' rx='1' opacity='.65'/><rect x='17' y='5' width='3' height='15' rx='1'/>",
      "iconColor": "#475569",
      "projection": "card-grid",
      "columns": 2,
      "sources": [],
      "statusFields": []
    },

    "capability-surface": {
      "name": "Capability Surface",
      "category": "delivery",
      "description": "Parallel status across a coherent system surface made up of capabilities, subsystems, or implementation tracks.",
      "structuralContract": "Two-column card grid of block-status items. Each item should represent a capability, module, subsystem, or comparable implementation track with concise state plus supporting notes and refs.",
      "notFor": [
        "single-column narrative surfaces",
        "dense catalogs of enabling work",
        "formal claims or investigation findings"
      ],

{
  "schemaVersion": 1,

  "entityTypes": {
    "figma-page": {
      "label": "Figma Page",
      "refRender": "link",
      "hrefTemplate": "{figmaCanonicalUrl}?node-id={nodeId}&m=dev",
      "displayKey": "id"
    },
    "figma-node": {
      "label": "Figma Node",
      "refRender": "link",
      "hrefTemplate": "{figmaCanonicalUrl}?node-id={nodeId}&m=dev",
      "displayKey": "id"
    },
    "code-file": {
      "label": "Code File",
      "refRender": "code-link",
      "hrefTemplate": "../{path}",
      "displayKey": "path"
    },
    "ticket": {
      "label": "Ticket",
      "refRender": "issue-link",
      "hrefTemplate": "{issueUrl}",
      "displayKey": "issueNumber",
      "displayPrefix": "#"
    },
    "ux-spec": {
      "label": "UX Spec",
      "refRender": "issue-link",
      "hrefTemplate": "{issueUrl}",
      "displayKey": "issueNumber",
      "displayPrefix": "#",
      "secondaryHref": "../{localArtifactPath}",
      "secondaryLabel": "spec"
    },
    "api-endpoint": {
      "label": "API Endpoint",
      "refRender": "code-badge",
      "displayKey": "ref"
    },
    "workflow": {
      "label": "Workflow",
      "refRender": "code-link",
      "hrefTemplate": "../{path}",
      "displayKey": "path"
    },
    "interaction-surface": {
      "label": "Interaction",
      "refRender": "anchor-link",
      "hrefTemplate": "#interaction-{id}",
      "displayKey": "name"
    },
    "flow-ref": {
      "label": "Flow",
      "refRender": "anchor-link",
      "hrefTemplate": "#flow-{id}",
      "displayKey": "name"
    },
    "content-source": {
      "label": "Source Material",
      "refRender": "anchor-link",
      "hrefTemplate": "#source-{id}",
      "displayKey": "name"
    },
    "formal-primitive": {
      "label": "Formal Primitive",
      "refRender": "code-badge",
      "displayKey": "ref"
    },
    "invariant": {
      "label": "Invariant",
      "refRender": "code-badge",
      "displayKey": "ref"
    },
    "authority": {
      "label": "Authority",
      "refRender": "code-badge",
      "displayKey": "ref"
    },
    "protocol-spec": {
      "label": "Protocol Spec",
      "refRender": "code-badge",
      "displayKey": "ref"
    }
  },

  "statusSets": {
    "page-status": {
      "values": ["ground-truth", "reference", "deprecated"],
      "tones": {
        "ground-truth": "positive",
        "reference": "neutral",
        "deprecated": "negative"
      }
    },
    "code-status": {
      "values": ["implemented", "partial", "drift", "not-started", "reference-only", "legacy-only"],
      "tones": {
        "implemented": "positive",
        "partial": "warning",
        "drift": "negative",
        "not-started": "neutral",
        "reference-only": "neutral",
        "legacy-only": "negative"
      }
    },
    "block-status": {
      "values": ["built", "partial", "not-built", "gap", "blocked"],
      "tones": {
        "built": "positive",
        "partial": "warning",
        "not-built": "neutral",
        "gap": "negative",
        "blocked": "negative"
      }
    },
    "integration-depth": {
      "values": ["screen-local", "hook-service-contract", "real-backend", "planned"],
      "tones": {
        "screen-local": "negative",
        "hook-service-contract": "warning",
        "real-backend": "positive",
        "planned": "neutral"
      }
    },
    "integration-source": {
      "values": ["real", "mock-api", "screen-local", "planned"],
      "tones": {
        "real": "positive",
        "mock-api": "warning",
        "screen-local": "negative",
        "planned": "neutral"
      }
    },
    "interaction-status": {
      "values": ["wired", "visual-only", "state-unwired", "navigation-unwired", "disabled-by-design"],
      "tones": {
        "wired": "positive",
        "visual-only": "warning",
        "state-unwired": "warning",
        "navigation-unwired": "negative",
        "disabled-by-design": "neutral"
      }
    },
    "probe-status": {
      "values": ["planned", "partial", "ready", "blocked"],
      "tones": {
        "planned": "neutral",
        "partial": "warning",
        "ready": "positive",
        "blocked": "negative"
      }
    },
    "probe-priority": {
      "values": ["blocking", "informational"],
      "tones": {
        "blocking": "warning",
        "informational": "neutral"
      },
      "labels": {
        "blocking": "Gate",
        "informational": "Informational"
      }
    },
    "conformance-state": {
      "values": ["not-assessed", "non-conformant", "partial-conformance", "conformant", "spec-ahead", "no-spec"],
      "tones": {
        "not-assessed": "neutral",
        "non-conformant": "negative",
        "partial-conformance": "warning",
        "conformant": "positive",
        "spec-ahead": "warning",
        "no-spec": "neutral"
      }
    },
    "model-integrity": {
      "values": ["not-started", "specified", "implemented", "verified", "canonical", "drift", "legacy"],
      "tones": {
        "not-started": "neutral",
        "specified": "neutral",
        "implemented": "warning",
        "verified": "positive",
        "canonical": "positive",
        "drift": "negative",
        "legacy": "negative"
      }
    },
    "content-lifecycle": {
      "values": ["not-started", "outlined", "drafted", "revised", "final", "blocked", "published"],
      "tones": {
        "not-started": "neutral",
        "outlined": "neutral",
        "drafted": "warning",
        "revised": "positive",
        "final": "positive",
        "blocked": "negative",
        "published": "positive"
      }
    }
  },

  "convergenceTypes": {
    "design-code-spec-flow": {
      "name": "Design–Code–Spec Flow",
      "icon": "<path d=\"M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14.5v-5l-4 4 4-9v5l4-4-4 9z\"/>",
      "projection": "card-grid",
      "columns": 2,
      "sources": [
        { "key": "pageIds", "entityType": "figma-page", "label": "Pages" },
        { "key": "defaultNodeIds", "entityType": "figma-node", "label": "Defaults" },
        { "key": "codeRefs", "entityType": "code-file", "label": "Code refs" },
        { "key": "specRefIds", "entityType": "ux-spec", "label": "UX spec refs", "resolve": true },
        { "key": "interactionSurfaceIds", "entityType": "interaction-surface", "label": "Tracked interactions", "resolve": true },
        { "key": "ticketIds", "entityType": "ticket", "label": "Tickets" },
        { "key": "notes", "entityType": null, "label": null }
      ],
      "statusFields": [
        { "key": "status", "statusSet": "page-status" },
        { "key": "codeStatus", "statusSet": "code-status" }
      ]
    },

    "component-status": {
      "name": "Component Status",
      "icon": "<path d=\"M3 13.5h2v5H3zm4-3h2v8H7zm4-4h2v12h-2zm4-3h2v15h-2z\"/>",
      "projection": "card-grid",
      "columns": 2,
      "sources": [

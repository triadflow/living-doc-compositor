{
  "$id": "https://triadflow.github.io/living-doc-compositor/schemas/living-doc-harness-iteration-proof.schema.json",
  "title": "living-doc-harness-iteration-proof/v1",
  "type": "object",
  "required": [
    "schema",
    "runId",
    "iteration",
    "createdAt",
    "livingDoc",
    "objectiveState",
    "workerEvidence",
    "stopVerdict",
    "skillsApplied",
    "proofGates",
    "nextIteration"
  ],
  "properties": {
    "schema": {
      "const": "living-doc-harness-iteration-proof/v1"
    },
    "runId": {
      "type": "string"
    },
    "iteration": {
      "type": "integer",
      "minimum": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "livingDoc": {
      "type": "object",
      "required": [
        "sourcePath",
        "beforeHash",
        "afterHash",
        "renderedHtml"
      ]
    },
    "objectiveState": {
      "type": "object",
      "required": [
        "objectiveHash",
        "stageBefore",
        "stageAfter",
        "unresolvedObjectiveTerms",
        "unprovenAcceptanceCriteria"
      ]
    },
    "workerEvidence": {
      "type": "object",
      "required": [
        "nativeInferenceTraceRefs",
        "wrapperLogRefs",
        "finalMessageSummary",
        "toolFailures",
        "filesChanged"
      ]
    },
    "stopVerdict": {
      "type": "object",
      "required": [
        "classification",
        "reasonCode",
        "confidence",
        "basis"
      ]
    },
    "skillsApplied": {
      "type": "array"
    },
    "proofGates": {
      "type": "object",
      "required": [
        "standaloneRun",
        "nativeTraceInspected",
        "livingDocRendered",
        "acceptanceCriteriaSatisfied",
        "evidenceBundleWritten",
        "closureAllowed"
      ]
    },
    "nextIteration": {
      "type": "object",
      "required": [
        "allowed",
        "mode"
      ]
    }
  }
}
